{
  "name": "json-builder",
  "version": "1.0.0",
  "description": "Markdown memo to JSON builder with real-time preview",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build && tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/node": "^20.12.7",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vitest": "^1.5.0",
    "@vitest/ui": "^1.5.0",
    "jsdom": "^24.0.0",
    "@testing-library/react": "^15.0.2",
    "@testing-library/jest-dom": "^6.4.2"
  }
}
